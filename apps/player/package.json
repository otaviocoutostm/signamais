{
  "name": "signamais-player",
  "version": "0.1.0",
  "description": "SignaMais — Player de Digital Signage",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "socket.io-client": "^4.7.5",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.signamais.player",
    "productName": "SignaMais Player",
    "directories": { "output": "dist" },
    "files": ["src/**/*", "node_modules/**/*"],
    "win": { "target": "nsis" },
    "linux": { "target": ["AppImage", "deb"], "category": "Utility" },
    "mac": { "target": "dmg" }
  }
}
