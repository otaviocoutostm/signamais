# API Dockerfile
FROM node:20-alpine AS builder
WORKDIR /app
COPY apps/api/package*.json ./
RUN npm ci --only=production
COPY apps/api/dist ./dist
COPY apps/api/prisma ./prisma
RUN npx prisma generate

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app .
EXPOSE 3001
CMD ["node", "dist/main.js"]
